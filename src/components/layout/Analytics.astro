---
// Sitewide marketing/analytics tags.
//
// Google Analytics 4 (G-1KNRPXM1BT). Loads immediately (matching Google's own
// gtag.js snippet) so it's caught by Google's tag-verification checks and
// counts fast-bouncing visitors (e.g. a mobile visitor tapping "Call" within
// a second of landing). Still gated to the production host so *.workers.dev
// previews and local dev never pollute real Analytics data. The script tag
// itself is `async`, so it never blocks parsing/rendering — no LCP cost.
const GA_ID = "G-1KNRPXM1BT";
const PROD_HOST = "riverbirchtreeservice.com";
---

<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
<script is:inline define:vars={{ GA_ID, PROD_HOST }}>
  if (
    location.hostname === PROD_HOST ||
    location.hostname === "www." + PROD_HOST
  ) {
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag("js", new Date());
    gtag("config", GA_ID);
  }
</script>
