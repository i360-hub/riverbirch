  home: '<path d="M4 11 12 5l8 6M6 10.5V19h12v-8.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  tree: '<path d="M12 3 7 11h3l-3.5 5.5h5V21h3v-4.5h5L16 11h3z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
  wind: '<path d="M3 8h10a2.5 2.5 0 1 0-2.5-2.5M3 12h13.5a2.5 2.5 0 1 1-2.5 2.5M3 16h8a2 2 0 1 1-2 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  bug: '<rect x="8" y="8.5" width="8" height="11" rx="4" fill="none" stroke="currentColor" stroke-width="2"/><path d="M9.2 8.2a2.8 2.8 0 0 1 5.6 0M10 5.6 8.7 4.3M14 5.6l1.3-1.3M8 11.5H4.3M16 11.5h3.7M8 15H4M16 15h4M8.6 18.3l-2 2.3M15.4 18.3l2 2.3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  document: '<path d="M6 3h7l5 5v13H6z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M13 3v5h5M9 13h6M9 16.5h6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  award: '<circle cx="12" cy="9" r="5" fill="none" stroke="currentColor" stroke-width="2"/><path d="M8.6 13 7 21l5-2.6L17 21l-1.6-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
  google: '<path d="M21 12.2c0-.7-.1-1.3-.2-1.9H12v3.7h5.1a4.4 4.4 0 0 1-1.9 2.9v2.4h3.1c1.8-1.7 2.7-4.1 2.7-7.1z" fill="#4285F4"/><path d="M12 21c2.5 0 4.6-.8 6.1-2.2l-3-2.3c-.8.6-1.9.9-3.1.9-2.4 0-4.4-1.6-5.1-3.8H3.7v2.4A9 9 0 0 0 12 21z" fill="#34A853"/><path d="M6.9 13.6a5.4 5.4 0 0 1 0-3.4V7.8H3.7a9 9 0 0 0 0 8.1z" fill="#FBBC05"/><path d="M12 6.6c1.3 0 2.5.5 3.5 1.4l2.6-2.6A9 9 0 0 0 3.7 7.8l3.2 2.5C7.6 8.1 9.6 6.6 12 6.6z" fill="#EA4335"/>',
  leaf: '<path d="M20 4C10 4 5 9 5 16c0 1.5.4 3 .9 4 6-8 11-9 12-9-4 1.5-7 4.6-9 9 2 .6 3.8.5 5.3-.1C18.5 18 21 13 20 4z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
  mountain: '<path d="M3 20h18L14 7l-3 5-2-3z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
};

const raw = paths[name] ?? "";
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="currentColor"
  aria-hidden={title ? undefined : "true"}
  role={title ? "img" : undefined}
  set:html={(title ? `<title>${title}</title>` : "") + raw}
></svg>

<style>
  svg {
    width: 1em;
    height: 1em;
    flex: none;
  }
</style>
