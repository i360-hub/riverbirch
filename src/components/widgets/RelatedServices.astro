---
import SectionHeader from "@components/ui/SectionHeader.astro";
import Icon from "@components/ui/Icon.astro";

interface Card {
  title: string;
  text: string;
  href: string;
}
interface Props {
  title?: string;
  sub?: string;
  cards?: Card[];
}
const {
  title = "Related Services",
  sub = "Other ways the River Birch Tree Service team can protect your home.",
  cards = [
    { title: "Burst Pipe Repair", text: "A burst or frozen pipe is one of the most common causes of water damage.", href: "/burst-pipe-repair" },
    { title: "Sewage Cleanup", text: "When the water is contaminated, we handle the safe, sanitized cleanup.", href: "/sewage-cleanup" },
    { title: "Basement Flooding", text: "Water heads for the lowest level of your home. We pump it out and dry it.", href: "/basement-flooding" },
    { title: "Mold Removal", text: "Water left too long grows mold. We remove it and stop it returning.", href: "/mold-removal" },
  ],
} = Astro.props;
---

<section class="cpr-section rel">
  <div class="cpr-section-inner">
    <SectionHeader title={title} sub={sub} />

    <ul class="rel__grid" role="list">
      {
        cards.map((c) => (
          <li class="rel__card">
            <a href={c.href} class="rel__link">
              <h3 class="rel__title">{c.title}</h3>
              <p class="rel__text">{c.text}</p>
              <span class="rel__more">Learn more <Icon name="arrow" /></span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .rel__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--cpr-space-lg);
  }
  .rel__card {
    background: var(--cpr-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--cpr-radius-lg);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .rel__card:hover {
    transform: translateY(-2px);
    box-shadow: var(--cpr-shadow-md);
    border-color: var(--cpr-red);
  }
  .rel__link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
    padding: var(--cpr-space-xl);
  }
  .rel__title {
    font-size: 1.15rem;
  }
  .rel__text {
    color: var(--cpr-slate);
    line-height: 1.55;
    font-size: 0.95rem;
  }
  .rel__more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: var(--cpr-space-sm);
    font-weight: 700;
    color: var(--cpr-red);
  }
  .rel__more :global(svg) {
    width: 1em;
    height: 1em;
  }
  @media (max-width: 900px) {
    .rel__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .rel__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
