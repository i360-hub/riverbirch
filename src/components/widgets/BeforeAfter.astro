---
// Side-by-side before/after from a real job, each with a labeled badge.
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import SectionHeader from "@components/ui/SectionHeader.astro";

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeAlt: string;
  afterAlt: string;
  title?: string;
  sub?: string;
  caption?: string;
  light?: boolean;
}
const {
  before, after, beforeAlt, afterAlt,
  title = "Before & After",
  sub,
  caption,
  light = true,
} = Astro.props;
---

<section class:list={["cpr-section", "beforeafter", { "cpr-section--light": light }]}>
  <div class="cpr-section-inner">
    <SectionHeader title={title} sub={sub} />
    <div class="ba__grid">
      <figure class="ba__item">
        <span class="ba__badge ba__badge--before">Before</span>
        <Image src={before} alt={beforeAlt} widths={[420, 700, 960]} sizes="(max-width: 760px) 92vw, 480px" loading="lazy" class="ba__img" />
      </figure>
      <figure class="ba__item">
        <span class="ba__badge ba__badge--after">After</span>
        <Image src={after} alt={afterAlt} widths={[420, 700, 960]} sizes="(max-width: 760px) 92vw, 480px" loading="lazy" class="ba__img" />
      </figure>
    </div>
    {caption && <p class="ba__caption">{caption}</p>}
  </div>
</section>

<style>
  .ba__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--cpr-space-lg);
  }
  .ba__item {
    position: relative;
    margin: 0;
    border-radius: var(--cpr-radius-lg);
    overflow: hidden;
    box-shadow: var(--cpr-shadow-md);
  }
  .ba__img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }
  .ba__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1;
    padding: 0.3rem 0.8rem;
    border-radius: var(--cpr-radius-pill, 999px);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--cpr-white);
  }
  .ba__badge--before {
    background: var(--cpr-slate, #64748b);
  }
  .ba__badge--after {
    background: var(--cpr-red);
  }
  .ba__caption {
    margin-top: var(--cpr-space-md);
    text-align: center;
    color: var(--cpr-slate-muted);
    font-size: 0.95rem;
  }
  @media (max-width: 620px) {
    .ba__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
