---
// Photo gallery grid — "Our crew at work" snapshots from around the High Country.
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import Icon from "@components/ui/Icon.astro";

interface Shot {
  image: ImageMetadata;
  alt: string;
}
interface Props {
  title?: string;
  sub?: string;
  shots: Shot[];
  ctaHref?: string;
  ctaLabel?: string;
  light?: boolean;
}
const {
  title = "Our Crew at Work",
  sub = "A few snapshots from recent tree jobs around Deep Gap, Boone, and the High Country.",
  shots,
  ctaHref,
  ctaLabel = "See more of our work",
  light = false,
} = Astro.props;
---

<section class:list={["cpr-section", "gallery", { "cpr-section--light": light }]}>
  <div class="cpr-section-inner">
    <SectionHeader title={title} sub={sub} />
    <ul class="gallery__grid" role="list">
      {
        shots.map((s) => (
          <li class="gallery__item">
            <Image
              src={s.image}
              alt={s.alt}
              widths={[320, 480, 640]}
              sizes="(max-width: 560px) 92vw, (max-width: 900px) 45vw, 30vw"
              loading="lazy"
              class="gallery__img"
            />
          </li>
        ))
      }
    </ul>
    {
      ctaHref && (
        <div class="gallery__foot">
          <a href={ctaHref} class="gallery__more" target="_blank" rel="noopener">
            {ctaLabel} <Icon name="arrow" />
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--cpr-space-md);
  }
  .gallery__item {
    border-radius: var(--cpr-radius-lg);
    overflow: hidden;
    box-shadow: var(--cpr-shadow-sm);
    background: var(--cpr-white);
  }
  .gallery__img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .gallery__item:hover .gallery__img {
    transform: scale(1.04);
  }
  .gallery__foot {
    margin-top: var(--cpr-space-xl);
    text-align: center;
  }
  .gallery__more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    color: var(--cpr-red);
  }
  .gallery__more :global(svg) {
    width: 1.05em;
    height: 1.05em;
  }
  @media (max-width: 700px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 440px) {
    .gallery__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
