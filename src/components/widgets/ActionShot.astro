---
// A real "on the job" photo paired with a short editorial blurb. Two-column so
// portrait and landscape shots both sit cleanly (no forced-aspect cropping).
// Image alternates side via the `flip` prop. Lazy + astro:assets optimized.
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow?: string;
  heading: string;
  text: string;
  flip?: boolean;
  light?: boolean;
}
const { image, alt, eyebrow = "On the job in the Carolinas", heading, text, flip = false, light = false } = Astro.props;
---

<section class:list={["cpr-section", "actionshot", { "cpr-section--light": light, "actionshot--flip": flip }]}>
  <div class="cpr-section-inner actionshot__inner">
    <div class="actionshot__media">
      <Image
        src={image}
        alt={alt}
        widths={[420, 700, 1000]}
        sizes="(max-width: 800px) 92vw, 560px"
        loading="lazy"
        class="actionshot__img"
      />
    </div>
    <div class="actionshot__body">
      <span class="actionshot__eyebrow">{eyebrow}</span>
      <h2 class="actionshot__heading">{heading}</h2>
      <p class="actionshot__text">{text}</p>
    </div>
  </div>
</section>

<style>
  .actionshot__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--cpr-space-2xl);
    align-items: center;
  }
  .actionshot--flip .actionshot__media {
    order: 2;
  }
  .actionshot__img {
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--cpr-radius-lg);
    box-shadow: var(--cpr-shadow-md);
    display: block;
  }
  .actionshot__eyebrow {
    display: block;
    color: var(--cpr-red);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.78rem;
    margin-bottom: 0.6rem;
  }
  .actionshot__heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--cpr-space-md);
  }
  .actionshot__text {
    color: var(--cpr-slate);
    font-size: 1.08rem;
    line-height: 1.65;
    max-width: 46ch;
  }
  @media (max-width: 800px) {
    .actionshot__inner {
      grid-template-columns: 1fr;
      gap: var(--cpr-space-lg);
    }
    .actionshot--flip .actionshot__media {
      order: 0;
    }
    .actionshot__img {
      max-height: 340px;
    }
  }
</style>
