---
import type { ImageMetadata } from "astro";
import ResponsivePicture from "@components/ui/ResponsivePicture.astro";
import Button from "@components/ui/Button.astro";
import Icon from "@components/ui/Icon.astro";
import { site } from "@data/site";

interface Cta {
  label: string;
  href: string;
}
interface Props {
  emergencyTag: string;
  h1Lines: string[];
  subtitle?: string;
  primaryCta?: Cta; // defaults to call
  secondaryCta?: Cta; // defaults to free estimate (#contact)
  trustSignals?: string[];
  image: ImageMetadata;
  imageAlt: string;
  /** object-position for the background, e.g. "center" or "50% 30%" */
  focalPoint?: string;
}

const {
  emergencyTag,
  h1Lines,
  subtitle,
  primaryCta = { label: `Call Now: ${site.phoneDisplay}`, href: site.phoneHref },
  secondaryCta = { label: "Get a Free Estimate", href: "#contact" },
  trustSignals = [],
  image,
  imageAlt,
  focalPoint = "center",
} = Astro.props;

const isCall = primaryCta.href.startsWith("tel:");
---

<section class="hero">
  <!-- Background image rendered as a real <Picture> (astro:assets) so it runs
       through the avif/webp pipeline with fetchpriority=high — replaces the
       live site's CSS background-image. -->
  <div class="hero__bg" aria-hidden="true">
    <ResponsivePicture
      src={image}
      alt={imageAlt}
      priority={true}
      sizes="100vw"
      pictureClass="hero__pic"
      objectPosition={focalPoint}
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <p class="hero__tag" set:html={emergencyTag} />
    <h1 class="hero__title">
      {h1Lines.map((line, i) => (<>{i > 0 && <br />}<span set:html={line} /></>))}
    </h1>
    {subtitle && <h2 class="hero__sub" set:html={subtitle} />}

    <div class="hero__actions">
      <Button href={primaryCta.href} variant={isCall ? "call" : "primary"} size="lg">{primaryCta.label}</Button>
      <Button href={secondaryCta.href} variant="outline" size="lg">{secondaryCta.label}</Button>
    </div>

    {
      trustSignals.length > 0 && (
        <ul class="hero__trust">
          {trustSignals.map((t) => (
            <li class="hero__trust-item">
              <Icon name="check" class="hero__trust-check" />
              <span set:html={t} />
            </li>
          ))}
        </ul>
      )
    }
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(520px, 78vh, 720px);
    padding: var(--cpr-space-3xl) var(--cpr-space-lg);
    color: var(--cpr-white);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__bg :global(.hero__pic),
  .hero__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(12, 34, 20, 0.86) 0%,
      rgba(12, 34, 20, 0.7) 45%,
      rgba(12, 34, 20, 0.4) 100%
    );
  }
  .hero__content {
    position: relative;
    z-index: 1;
    max-width: var(--cpr-max-width);
    margin-inline: auto;
    width: 100%;
  }
  .hero__tag {
    display: inline-block;
    background: rgba(12, 34, 20, 0.85);
    color: var(--cpr-white);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.45rem 1.1rem;
    border-radius: var(--cpr-radius-pill);
    border: 1px solid rgba(200, 153, 46, 0.55);
    margin-bottom: var(--cpr-space-lg);
  }
  .hero__title {
    font-size: clamp(2rem, 5.2vw, 3.4rem);
    color: var(--cpr-white);
    max-width: 15ch;
    text-wrap: balance;
  }
  .hero__sub {
    margin-top: var(--cpr-space-md);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    font-weight: 500;
    line-height: 1.6;
    max-width: 52ch;
    color: rgba(255, 255, 255, 0.9);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--cpr-space-md);
    margin-top: var(--cpr-space-xl);
  }
  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--cpr-space-md) var(--cpr-space-lg);
    margin-top: var(--cpr-space-xl);
  }
  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .hero__trust-check {
    width: 1.2em;
    height: 1.2em;
    color: #4ade80;
    flex: none;
  }
  @media (max-width: 600px) {
    .hero {
      min-height: 0;
      padding: var(--cpr-space-2xl) var(--cpr-space-md);
    }
    .hero__title {
      max-width: none;
    }
  }
</style>
