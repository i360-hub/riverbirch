---
// "Service Area" section: heading, town links, SAB contact card, static coverage
// map (SVG) + interactive Google Maps embed (or a styled fallback link when no
// Maps Embed API key is set). Service Area Business — no street address shown.
import SectionHeader from "@components/ui/SectionHeader.astro";
import Icon from "@components/ui/Icon.astro";
import { site } from "@data/site";
import { hasMapsKey } from "@data/maps";

interface CityLink {
  label: string;
  href: string;
}
interface Props {
  title?: string;
  sub?: string;
  infoHeading?: string;
  infoBlurb?: string;
  citiesLabel?: string;
  cities?: CityLink[];
  mapSrc?: string;
  mapTitle?: string;
  mapLink?: string;
  showStaticMap?: boolean;
}
const {
  title = "Serving Deep Gap, Boone & the High Country",
  sub = "Locally owned and based in Deep Gap, we cover Watauga County plus neighboring Ashe & Avery Counties and the surrounding High Country. Pick your town for local details.",
  infoHeading = "Fast Response Across the High Country",
  infoBlurb = "From our Deep Gap base we reach Boone, Blowing Rock, Banner Elk, West Jefferson and the rest of Watauga, Ashe & Avery Counties quickly — and we travel for large jobs beyond.",
  citiesLabel = "Towns We Serve",
  cities = site.footerServiceAreas,
  mapSrc = site.mapEmbedSrc,
  mapTitle = `${site.name} service area map`,
  mapLink = site.mapLink,
  showStaticMap = true,
} = Astro.props;
---

<section class="cpr-section area">
  <div class="cpr-section-inner">
    <SectionHeader title={title} sub={sub} />

    <div class="area__grid">
      <div class="area__info">
        {infoHeading && <h3 class="area__infohead">{infoHeading}</h3>}
        {infoBlurb && <p class="area__infoblurb">{infoBlurb}</p>}
        <p class="area__label">{citiesLabel}</p>
        <ul class="area__cities" role="list">
          {
            cities.map((c) => (
              <li>
                <a href={c.href}><span class="area__dot" aria-hidden="true" />{c.label}</a>
              </li>
            ))
          }
        </ul>

        <div class="area__nap">
          <p class="area__naptitle">{site.legalName}</p>
          <address class="area__address">
            <Icon name="pin" /> {site.address.city}, {site.address.state} · {site.address.region}
          </address>
          <p class="area__sab">Service Area Business — we come to you. No storefront to visit.</p>
          <a href={site.phoneHref} class="area__phone"><Icon name="phone" /> {site.phoneDisplay}</a>
        </div>
      </div>

      <div class="area__mapcol">
        {
          showStaticMap && (
            <img
              class="area__staticmap"
              src="/river-birch-service-area-map.svg"
              alt="Map of River Birch Tree Service's coverage across Watauga County and the High Country of North Carolina, centered on Deep Gap"
              width="820"
              height="620"
              loading="lazy"
            />
          )
        }
        <div class="area__map">
          {
            hasMapsKey ? (
              <iframe
                src={mapSrc}
                title={mapTitle}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              />
            ) : (
              <a class="area__mapfallback" href={mapLink} rel="noopener" target="_blank">
                <Icon name="pin" />
                <span>View our {site.address.region} service area on Google Maps</span>
              </a>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .area__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--cpr-space-2xl);
    align-items: start;
  }
  .area__infohead {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
  }
  .area__infoblurb {
    color: var(--cpr-slate);
    margin-bottom: var(--cpr-space-lg);
  }
  .area__label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--cpr-red);
    margin-bottom: var(--cpr-space-md);
  }
  .area__cities {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
    margin-bottom: var(--cpr-space-xl);
  }
  .area__cities a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.5rem;
    font-weight: 600;
    color: var(--cpr-navy);
    border-radius: var(--cpr-radius-sm);
    transition: color 0.15s ease;
  }
  .area__cities a:hover {
    color: var(--cpr-red);
  }
  .area__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--cpr-gold);
    flex: none;
  }
  .area__nap {
    border-top: 1px solid rgba(18, 51, 30, 0.1);
    padding-top: var(--cpr-space-lg);
  }
  .area__naptitle {
    font-weight: 700;
    color: var(--cpr-navy);
    margin-bottom: 0.5rem;
  }
  .area__address {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-style: normal;
    color: var(--cpr-slate);
    margin-bottom: 0.35rem;
  }
  .area__address :global(svg) {
    color: var(--cpr-gold);
    flex: none;
  }
  .area__sab {
    font-size: 0.9rem;
    color: var(--cpr-slate-muted);
    margin-bottom: 0.75rem;
  }
  .area__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--cpr-navy);
  }
  .area__phone :global(svg) {
    color: var(--cpr-gold);
  }
  .area__mapcol {
    display: flex;
    flex-direction: column;
    gap: var(--cpr-space-md);
  }
  .area__staticmap {
    width: 100%;
    height: auto;
    border-radius: var(--cpr-radius-lg);
    box-shadow: var(--cpr-shadow-md);
    border: 1px solid rgba(18, 51, 30, 0.08);
    background: var(--cpr-off-white);
  }
  .area__map {
    border-radius: var(--cpr-radius-lg);
    overflow: hidden;
    box-shadow: var(--cpr-shadow-md);
    min-height: 240px;
  }
  .area__map iframe {
    width: 100%;
    height: 100%;
    min-height: 320px;
    border: 0;
    display: block;
  }
  .area__mapfallback {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    height: 100%;
    min-height: 200px;
    padding: var(--cpr-space-xl);
    text-align: center;
    background: var(--cpr-navy);
    color: var(--cpr-white);
    font-weight: 700;
  }
  .area__mapfallback:hover {
    background: var(--cpr-dark);
  }
  .area__mapfallback :global(svg) {
    width: 2rem;
    height: 2rem;
    color: var(--cpr-gold);
  }
  @media (max-width: 820px) {
    .area__grid {
      grid-template-columns: 1fr;
      gap: var(--cpr-space-xl);
    }
  }
  @media (max-width: 440px) {
    .area__cities {
      grid-template-columns: 1fr;
    }
  }
</style>
