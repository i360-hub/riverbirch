---
// Dynamic Tier-2 town page. Renders the town stack from locations.ts.
// Produces /tree-service-deep-gap-nc, /tree-service-boone-nc, … at their exact URLs.
import type { ImageMetadata } from "astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/widgets/Hero.astro";
import StatStrip from "@components/widgets/StatStrip.astro";
import LocalContent from "@components/widgets/LocalContent.astro";
import Reviews from "@components/widgets/Reviews.astro";
import Faq from "@components/widgets/Faq.astro";
import ServiceArea from "@components/widgets/ServiceArea.astro";
import FinalCta from "@components/widgets/FinalCta.astro";
import ContactForm from "@components/widgets/ContactForm.astro";
import { locations } from "@data/locations";
import { reviewsForCity } from "@data/reviews";
import { mapEmbed, mapsLink } from "@data/maps";

import heroA from "@assets/images/high-country-tree-removal-climber-mountain.jpg";
import heroB from "@assets/images/boone-nc-tree-climber-blue-sky.jpg";
import heroC from "@assets/images/blowing-rock-nc-view-clearing-mountain-pond.jpg";
const heroPool: ImageMetadata[] = [heroA, heroB, heroC];

export function getStaticPaths() {
  return Object.keys(locations).map((town) => ({ params: { town } }));
}

const { town } = Astro.params;
const loc = locations[town];

// Vary the hero across towns without per-town image data (deterministic by slug).
const heroImg = heroPool[loc.slug.length % heroPool.length];

const townMapSrc = mapEmbed(`${loc.name}, ${loc.state}`, 12);
const townMapLink = mapsLink(`${loc.name}, ${loc.state}`);

const faqSchema = [
  {
    "@type": "FAQPage",
    mainEntity: loc.faq.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a.replace(/<[^>]+>/g, "") },
    })),
  },
];

const origin = Astro.site!.toString().replace(/\/$/, "");
const pageUrl = `${origin}/tree-service-${loc.slug}`;
const townServiceSchema = {
  "@type": "Service",
  "@id": `${pageUrl}#service`,
  serviceType: "Tree Service",
  name: `Tree Service in ${loc.name}, ${loc.state}`,
  url: pageUrl,
  description: loc.metaDescription,
  provider: { "@id": `${origin}/#business` },
  areaServed: { "@type": "City", name: `${loc.name}, ${loc.state}` },
  mainEntityOfPage: { "@id": `${pageUrl}#webpage` },
};
---

<BaseLayout
  title={loc.title}
  description={loc.metaDescription}
  path={`/tree-service-${loc.slug}`}
  schema={[townServiceSchema, ...faqSchema]}
  breadcrumb={[
    { name: "Service Areas", item: `${origin}/service-areas` },
    { name: `${loc.name}, ${loc.state}`, item: pageUrl },
  ]}
>
  <Hero
    emergencyTag={loc.heroTag}
    h1Lines={[loc.h1]}
    subtitle={loc.heroSub}
    trustSignals={loc.heroTrust}
    image={heroImg}
    imageAlt={`River Birch Tree Service serving ${loc.name}, ${loc.state}`}
    focalPoint="50% 45%"
  />
  <StatStrip stats={loc.stats} />
  <LocalContent blocks={loc.body} />
  <Reviews reviews={reviewsForCity(town)} title={loc.reviewsTitle} sub={loc.reviewsSub} light={true} />
  <Faq title={loc.faqTitle} sub={loc.faqSub} items={loc.faq} />
  <ServiceArea
    title={loc.areaTitle}
    sub={loc.areaSub}
    infoHeading={loc.areaInfoHeading}
    infoBlurb={loc.areaInfoBlurb}
    cities={loc.nearby}
    mapSrc={townMapSrc}
    mapLink={townMapLink}
  />
  <FinalCta heading={loc.finalCta} />
  <ContactForm heading={loc.contactHeading} description={loc.contactDesc} formName={`${loc.name} Estimate Request`} />
</BaseLayout>
