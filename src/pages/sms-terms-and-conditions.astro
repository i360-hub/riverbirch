---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/layout/PageHeader.astro";
import LocalContent from "@components/widgets/LocalContent.astro";
import FinalCta from "@components/widgets/FinalCta.astro";
import { site } from "@data/site";

const blocks = [
  { tag: "p", html: `These SMS Terms &amp; Conditions govern text-message communications with River Birch Tree Service LLC ("River Birch," "we," "us"). By providing your phone number and opting in, you agree to the terms below.` },
  { tag: "h2", html: "Consent to Receive Messages" },
  { tag: "p", html: `When you provide your mobile number — for example, on our estimate request form or by texting us — you consent to receive SMS/MMS messages from River Birch about your estimate, scheduling, service updates, and occasional offers. Consent is not a condition of purchase.` },
  { tag: "h2", html: "Message Frequency &amp; Rates" },
  { tag: "p", html: `Message frequency varies based on your interactions with us. Message and data rates may apply, depending on your mobile carrier and plan.` },
  { tag: "h2", html: "Opting Out" },
  { tag: "p", html: `You can opt out of text messages at any time by replying <strong>STOP</strong> to any message. You will receive a confirmation and no further texts unless you opt back in. Reply <strong>HELP</strong> for help, or contact us directly.` },
  { tag: "h2", html: "Privacy" },
  { tag: "p", html: `We do not sell or share your mobile number with third parties for their marketing. See our <a href="/privacy">Privacy Policy</a> for how we handle your information.` },
  { tag: "h2", html: "Contact" },
  // The SMS program is registered to the real business number, so this legal
  // page cites napPhone — not the sitewide call-tracking number.
  { tag: "p", html: `Questions about these terms? Call us at <a href="${site.napPhoneHref}">${site.napPhoneDisplay}</a> or email <a href="mailto:${site.email}">${site.email}</a>.` },
];
---

<BaseLayout
  title="SMS Terms & Conditions | River Birch Tree Service"
  description="Review River Birch Tree Service's SMS terms for text-message communications and marketing notifications. Deep Gap, NC."
  path="/sms-terms-and-conditions"
  noindex={true}
>
  <PageHeader eyebrow="Legal" title="SMS Terms & Conditions" />
  <LocalContent blocks={blocks} />
  <FinalCta heading="Questions? Talk to Our Team 24/7." />
</BaseLayout>
