---
// Contact page — full lead form + phone / email, and the service map.
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/layout/PageHeader.astro";
import ContactForm from "@components/widgets/ContactForm.astro";
import ServiceArea from "@components/widgets/ServiceArea.astro";
import { site } from "@data/site";

const origin = Astro.site!.toString().replace(/\/$/, "");
const title = "Contact River Birch Tree Service | Free Estimates | Deep Gap, NC";
const description =
  "Contact River Birch Tree Service for a free estimate on tree removal, storm cleanup, trimming, stump grinding, or land clearing in Boone & the High Country. Call (828) 818-8505. 24/7 emergencies.";
---

<BaseLayout title={title} description={description} path="/contact" breadcrumb={[{ name: "Contact", item: `${origin}/contact` }]}>
  <PageHeader
    eyebrow="Free Estimates · 24/7 Emergencies"
    title="Contact River Birch Tree Service"
    subtitle="Call us at (828) 818-8505, or send the details below and we'll get right back to you. Based in Deep Gap and serving Watauga, Ashe &amp; Avery Counties — we come to you."
    ctas={[
      { label: `Call ${site.phoneDisplay}`, href: site.phoneHref, variant: "call" },
      { label: "Get a Free Estimate", href: "#contact", variant: "outline" },
    ]}
  />
  <ContactForm
    heading="Get Your Free Estimate"
    description="Tell us about your tree, storm cleanup, or clearing project. For a tree that's already down, call us anytime — we answer 24/7."
    formName="Contact Page Estimate Request"
    formSrc={site.ghlContactFormSrc}
    formId={site.ghlContactFormId}
  />
  <ServiceArea />
</BaseLayout>
