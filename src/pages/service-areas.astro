---
// Service Areas hub — links to all High Country town pages, grouped by county
// (Watauga home base + Ashe & Avery).
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/layout/PageHeader.astro";
import ServiceArea from "@components/widgets/ServiceArea.astro";
import FinalCta from "@components/widgets/FinalCta.astro";
import ContactForm from "@components/widgets/ContactForm.astro";
import Icon from "@components/ui/Icon.astro";
import { locations, alsoServed } from "@data/locations";
import { site } from "@data/site";

const towns = Object.values(locations);
const origin = Astro.site!.toString().replace(/\/$/, "");

// Group town pages by county so the hub reads as a real three-county footprint.
const countyOrder = ["Watauga County", "Ashe County", "Avery County"];
const townsByCounty = countyOrder
  .map((county) => ({ county, towns: towns.filter((t) => t.county === county) }))
  .filter((g) => g.towns.length > 0);

const title = "Service Areas | Tree Service Across Watauga, Ashe & Avery Counties";
const description =
  "River Birch Tree Service covers Boone, Blowing Rock, Banner Elk, Beech Mountain, West Jefferson and the High Country across Watauga, Ashe & Avery Counties, NC. Fully insured, 24/7 emergency response. Call (828) 964-6567.";

const itemList = {
  "@type": "ItemList",
  "@id": `${origin}/service-areas#towns`,
  name: "River Birch Tree Service — Service Areas",
  itemListElement: towns.map((t, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: `${t.name}, ${t.state}`,
    url: `${origin}/tree-service-${t.slug}`,
  })),
};
---

<BaseLayout title={title} description={description} path="/service-areas" schema={[itemList]} breadcrumb={[{ name: "Service Areas", item: `${origin}/service-areas` }]}>
  <PageHeader
    eyebrow="Watauga, Ashe & Avery Counties"
    title="Where River Birch Works"
    subtitle="Locally owned and based in Deep Gap, we serve tree removal, storm &amp; ice cleanup, land clearing, trimming, stump grinding, and view clearing across Watauga County and neighboring Ashe &amp; Avery Counties — and travel for large jobs beyond."
    ctas={[
      { label: `Call ${site.phoneDisplay}`, href: site.phoneHref, variant: "call" },
      { label: "Get a Free Estimate", href: "#contact", variant: "outline" },
    ]}
  />

  <section class="cpr-section">
    <div class="cpr-section-inner">
      <h2 class="towns__h">Towns We Serve Across the High Country</h2>
      <p class="towns__lede">Click your town for local tree service details. Don't see your spot? We cover the surrounding areas too — just <a href="/contact">give us a call</a>.</p>
      {
        townsByCounty.map((group) => (
          <div class="towns__county">
            <h3 class="towns__countyh">{group.county}</h3>
            <ul class="towns__grid" role="list">
              {group.towns.map((t) => (
                <li>
                  <a href={`/tree-service-${t.slug}`} class="towns__card">
                    <span class="towns__dot" aria-hidden="true" />
                    <span class="towns__name">{t.name}, {t.state}</span>
                    <Icon name="arrow" class="towns__arrow" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <p class="towns__also">River Birch also serves {alsoServed.join(", ")}, and the surrounding High Country and NC/TN line communities. <a href="/contact">Call us</a> — if you're anywhere near Watauga, Ashe, or Avery County, we cover you.</p>
    </div>
  </section>

  <ServiceArea />
  <FinalCta heading="Need a Tree Handled in the High Country? Let's Talk." />
  <ContactForm formName="Service Areas Estimate Request" />
</BaseLayout>

<style>
  .towns__h {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }
  .towns__lede {
    margin: 0.6rem 0 var(--cpr-space-xl);
    color: var(--cpr-slate);
    font-size: 1.05rem;
    max-width: 60ch;
  }
  .towns__lede a {
    color: var(--cpr-red);
    font-weight: 600;
    text-decoration: underline;
  }
  .towns__county {
    margin-bottom: var(--cpr-space-xl);
  }
  .towns__countyh {
    font-size: 1.15rem;
    color: var(--cpr-navy);
    margin: 0 0 0.9rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--cpr-gold);
    display: inline-block;
  }
  .towns__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }
  .towns__card {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--cpr-bg-light);
    border: 1px solid rgba(18, 51, 30, 0.08);
    border-radius: var(--cpr-radius-md);
    padding: 0.9rem 1.1rem;
    font-weight: 600;
    color: var(--cpr-navy);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .towns__card:hover {
    transform: translateY(-1px);
    box-shadow: var(--cpr-shadow-md);
    border-color: var(--cpr-red);
  }
  .towns__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--cpr-gold);
    flex: none;
  }
  .towns__name {
    flex: 1;
  }
  .towns__arrow {
    width: 1em;
    height: 1em;
    color: var(--cpr-red);
  }
  @media (max-width: 900px) {
    .towns__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .towns__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
