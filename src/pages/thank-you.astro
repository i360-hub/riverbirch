---
// GoHighLevel form-submission redirect target. Not indexed, not in sitemap.
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/ui/Button.astro";
import Icon from "@components/ui/Icon.astro";
import { site } from "@data/site";
---

<BaseLayout
  title="Thank You For Your Interest"
  description="Thank you for your interest."
  path="/thank-you"
  noindex={true}
>
  <section class="thanks">
    <div class="thanks__inner">
      <span class="thanks__mark"><Icon name="check" /></span>
      <h1 class="thanks__h1">Thank you for reaching out to River Birch Tree Service.</h1>
      <p class="thanks__lead">
        One of our team members will reach out to discuss your project. If you need to talk with
        someone right away, please give us a call.
      </p>
      <Button href={site.phoneHref} variant="call" size="lg">Call 24/7: {site.phoneDisplay}</Button>
      <p class="thanks__back"><a href="/">← Back to homepage</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks {
    display: grid;
    place-items: center;
    min-height: 60vh;
    padding: var(--cpr-space-3xl) var(--cpr-space-lg);
    text-align: center;
  }
  .thanks__inner {
    max-width: 620px;
  }
  .thanks__mark {
    display: inline-grid;
    place-items: center;
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    background: rgba(22, 163, 74, 0.12);
    color: #16a34a;
    font-size: 2rem;
    margin-bottom: var(--cpr-space-lg);
  }
  .thanks__h1 {
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
  }
  .thanks__lead {
    margin: var(--cpr-space-md) 0 var(--cpr-space-xl);
    font-size: 1.15rem;
    color: var(--cpr-slate);
  }
  .thanks__back {
    margin-top: var(--cpr-space-lg);
  }
  .thanks__back a {
    color: var(--cpr-slate-muted);
    font-weight: 600;
  }
  .thanks__back a:hover {
    color: var(--cpr-red);
  }
</style>
