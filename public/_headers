# Cloudflare Pages headers — caching + baseline security.

# Content-hashed build assets never change: cache hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static image/font assets copied from public/
/*.png
  Cache-Control: public, max-age=604800
/*.jpg
  Cache-Control: public, max-age=604800
/*.webp
  Cache-Control: public, max-age=604800
/*.svg
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800

# Baseline security headers for every HTML response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Keep the pages.dev alias (and per-deploy hash previews) out of search engines.
# Host-scoped: these rules never apply on riverbirchtreeservice.com.
https://:project.pages.dev/*
  X-Robots-Tag: noindex
https://:version.:project.pages.dev/*
  X-Robots-Tag: noindex
